{
  "name": "vocablens",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "dev:anpanda": "pnpm --filter anpanda dev",
    "dev:web": "pnpm --filter vocablens-web dev",
    "build:anpanda": "pnpm --filter anpanda build",
    "build:web": "pnpm --filter vocablens-web build",
    "build:extension": "echo 'Extension: load apps/extension/ as unpacked in Chrome'",
    "build": "turbo build",
    "lint": "turbo lint"
  },
  "devDependencies": {
    "turbo": "^2.0.0"
  }
}
